# Copy this to .env and fill in your keys

# Image generation (primary)
REPLICATE_API_TOKEN=your_replicate_token_here

# Image generation (fallback — optional)
FAL_KEY=your_fal_key_here

# Which provider to use: replicate | fal
IMAGE_PROVIDER=replicate

# Replicate model — FLUX for line art
REPLICATE_MODEL=black-forest-labs/flux-1.1-pro

# Storage backend: local | r2
STORAGE_BACKEND=local
# Storage root for local backend (relative to backend/ working dir)
STORAGE_DIR=storage

# Cloudflare R2 (S3-compatible object storage) — required when STORAGE_BACKEND=r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=coloring-book-studio
# Optional: defaults to https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT=
# Public base URL for serving assets (r2.dev URL or your custom domain)
R2_PUBLIC_BASE_URL=
# R2 always uses region "auto"
R2_REGION=auto

# Neon Postgres + pgvector — when set, replaces SQLite; async driver
# Format: postgresql+asyncpg://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Mistral — PDF parsing + OCR (document AI)
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Server
HOST=127.0.0.1
PORT=8000
