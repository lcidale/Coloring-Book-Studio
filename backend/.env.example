# Copy this to .env and fill in your keys

# Image generation (primary)
REPLICATE_API_TOKEN=your_replicate_token_here

# Image generation (fallback — optional)
FAL_KEY=your_fal_key_here

# Image generation — Google Nano Banana (Gemini). Either var configures it;
# the SDK auto-reads GOOGLE_API_KEY, GEMINI_API_KEY is also accepted.
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# Default provider used when the in-app global setting is unset:
#   replicate | fal | gemini (aka nanobanana)
# At runtime the in-app global setting (GET/PUT /api/settings) takes precedence.
IMAGE_PROVIDER=replicate

# Per-provider model overrides (fall back to the registry default if unset):
#   replicate: black-forest-labs/flux-1.1-pro | black-forest-labs/flux-dev
#   fal:       fal-ai/flux/schnell | fal-ai/flux/dev
#   gemini:    gemini-2.5-flash-image
REPLICATE_MODEL=black-forest-labs/flux-1.1-pro
FAL_MODEL=fal-ai/flux/schnell
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Storage backend: local | r2
STORAGE_BACKEND=local
# Storage root for local backend (relative to backend/ working dir)
STORAGE_DIR=storage

# Cloudflare R2 (S3-compatible object storage) — required when STORAGE_BACKEND=r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=coloring-book-studio
# Optional: defaults to https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT=
# Public base URL for serving assets (r2.dev URL or your custom domain)
R2_PUBLIC_BASE_URL=
# R2 always uses region "auto"
R2_REGION=auto

# Neon Postgres + pgvector — when set, replaces SQLite; async driver
# Format: postgresql+asyncpg://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Mistral — PDF parsing + OCR (document AI)
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Canva Connect API — cover/marketing asset generation
# Obtain a Bearer access token via the Canva OAuth2 flow:
#   https://www.canva.dev/docs/connect/authentication/
# Required scope: design:content:write (for creating designs)
CANVA_ACCESS_TOKEN=your_canva_access_token_here
# Optional: override the Canva Connect API base URL (leave blank for default)
CANVA_API_BASE_URL=https://api.canva.com/rest/v1

# Server
HOST=127.0.0.1
PORT=8000
